# ════════════════════════════════════════════════════════════════
# RegRadar -- Environment Configuration Template
#
# Copy this file to .env and fill in values.
# .env is .gitignored -- never commit secrets.
#
# Required vars: app refuses to start without these (see backend/utils/env.py)
# Optional vars: have sensible defaults
# ════════════════════════════════════════════════════════════════


# ────────────────────────────────────────────────────────────────
# GOOGLE CLOUD / VERTEX AI  (required)
# ────────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=gen-lang-client-0677154031
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=True

# Optional -- API key auth for quick scripts (Vertex ADC preferred for app)
GEMINI_API_KEY=

# ────────────────────────────────────────────────────────────────
# OPENROUTER  (required -- LLM fallback for resilience)
# ────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ────────────────────────────────────────────────────────────────
# CLICKHOUSE  (required)
# Pick local OR cloud -- not both.
# ────────────────────────────────────────────────────────────────

# LOCAL (default for dev -- use docker-compose.yml)
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_SECURE=false
CLICKHOUSE_DATABASE=regradar

# CLOUD (uncomment for demo -- comment out the LOCAL block above)
# CLICKHOUSE_HOST=xxx.us-east-1.aws.clickhouse.cloud
# CLICKHOUSE_PORT=8443
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=
# CLICKHOUSE_SECURE=true
# CLICKHOUSE_DATABASE=regradar

# ────────────────────────────────────────────────────────────────
# NIMBLE  (required -- primary web scraping)
# Sign up: nimbleway.com  |  5,000 page free trial
# ────────────────────────────────────────────────────────────────
NIMBLE_API_KEY=

# ────────────────────────────────────────────────────────────────
# FIRECRAWL  (required -- silent fallback scraper)
# Existing key from prior projects
# ────────────────────────────────────────────────────────────────
FIRECRAWL_API_KEY=

# ────────────────────────────────────────────────────────────────
# DATADOG  (required -- observability + monitoring)
# Sign up: datadoghq.com  |  14-day trial, no card
# ────────────────────────────────────────────────────────────────
DD_API_KEY=
DD_SITE=datadoghq.com
DD_SERVICE=regradar-backend
DD_ENV=hackathon

# LLM Observability
DD_LLMOBS_ENABLED=1
DD_LLMOBS_AGENTLESS_ENABLED=1
DD_LLMOBS_ML_APP=regradar

# ────────────────────────────────────────────────────────────────
# LUMINAI  (required for action execution -- provided AT hackathon)
# Leave blank until on-site
# ────────────────────────────────────────────────────────────────
LUMINAI_API_KEY=
LUMINAI_BASE_URL=
LUMINAI_WORKSPACE_ID=

# ────────────────────────────────────────────────────────────────
# APP CONFIG  (optional -- sensible defaults)
# ────────────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8000
APP_LOG_LEVEL=INFO
APP_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
APP_WS_HEARTBEAT_SECONDS=30

# ────────────────────────────────────────────────────────────────
# AGENT CONFIG  (optional -- override only if tuning)
# ────────────────────────────────────────────────────────────────
WATCHER_API_POLL_INTERVAL_SECONDS=900
WATCHER_SCRAPE_INTERVAL_SECONDS=3600
AGENT_MAX_PER_MESSAGE=3
AGENT_PRIMARY_THRESHOLD=0.85
AGENT_SUPPORTING_THRESHOLD=0.65
AGENT_CROSS_TALK_THRESHOLD=0.50
AUDITOR_REJECT_BLOCKS_DELIVERY=true
