# ════════════════════════════════════════════════════════════════
# RegRadar -- Environment Configuration Template
# Updated 2026-05-23: Gemini 3.5 Flash defaults, Senso added, Luminai removed
#
# Copy this file to .env and fill in values.
# .env is .gitignored -- never commit secrets.
# ════════════════════════════════════════════════════════════════


# ────────────────────────────────────────────────────────────────
# GOOGLE CLOUD / VERTEX AI  (required)
# ────────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=gen-lang-client-0677154031
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=True

# Model selection (verified current as of May 2026)
# - gemini-3.5-flash: GA May 19, 2026 at I/O. $1.50/$9 per 1M. Beats 3.1 Pro on agentic benchmarks. Default workhorse.
# - gemini-3.1-pro: Still the flagship reasoning model until 3.5 Pro lands June 2026. Used by the Judge. $2/$12 per 1M.
# - gemini-embedding-001: Current embedding leader on MTEB. $0.15/M. 3072 dims w/ Matryoshka truncation.
GEMINI_MODEL_DEFAULT=gemini-3.5-flash
GEMINI_MODEL_REASONING=gemini-3.1-pro
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Optional -- API key auth for quick scripts (Vertex ADC preferred for app)
GEMINI_API_KEY=

# ────────────────────────────────────────────────────────────────
# OPENROUTER  (required -- LLM fallback for resilience)
# ────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ────────────────────────────────────────────────────────────────
# CLICKHOUSE  (required)
# Pick local OR cloud -- not both.
# ────────────────────────────────────────────────────────────────

# LOCAL (default for dev -- use docker-compose.yml)
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_SECURE=false
CLICKHOUSE_DATABASE=regradar

# CLOUD (uncomment for demo)
# CLICKHOUSE_HOST=xxx.us-east-1.aws.clickhouse.cloud
# CLICKHOUSE_PORT=8443
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=
# CLICKHOUSE_SECURE=true
# CLICKHOUSE_DATABASE=regradar

# ────────────────────────────────────────────────────────────────
# NIMBLE  (required -- primary web scraping)
# Sign up: nimbleway.com  |  5,000 page free trial
# ────────────────────────────────────────────────────────────────
NIMBLE_API_KEY=

# ────────────────────────────────────────────────────────────────
# FIRECRAWL  (required -- silent fallback scraper)
# ────────────────────────────────────────────────────────────────
FIRECRAWL_API_KEY=

# ────────────────────────────────────────────────────────────────
# DATADOG  (required -- observability + monitoring)
# Auto-instruments google-genai SDK via ddtrace-run
# ────────────────────────────────────────────────────────────────
DD_API_KEY=
DD_SITE=datadoghq.com
DD_SERVICE=regradar-backend
DD_ENV=hackathon

# LLM Observability (auto-instrumentation enabled)
DD_LLMOBS_ENABLED=1
DD_LLMOBS_AGENTLESS_ENABLED=1
DD_LLMOBS_ML_APP=regradar

# ────────────────────────────────────────────────────────────────
# SENSO  (required for cited.md publishing prize track)
# Sign up: senso.ai  |  Get API key from docs.senso.ai
# ────────────────────────────────────────────────────────────────
SENSO_API_KEY=
SENSO_BASE_URL=https://apiv2.senso.ai
SENSO_PUBLISH_NAMESPACE=regradar       # appears in cited.md/regradar/...

# ────────────────────────────────────────────────────────────────
# x402 PAYMENT RAIL  (required for monetization beat in demo)
# Coinbase Developer Platform. Settlement on Base in USDC.
# Docs: https://x402.org  |  Sign up: portal.cdp.coinbase.com
# ────────────────────────────────────────────────────────────────
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_NETWORK=base                                  # base | base-sepolia (testnet) | solana
X402_RECIPIENT_ADDRESS=                            # our wallet to receive USDC
X402_PRICE_USDC_PER_BRIEF=0.001                    # $0.001 per compliance brief fetch
CDP_API_KEY_ID=                                    # from Coinbase Developer Portal
CDP_API_KEY_SECRET=

# ────────────────────────────────────────────────────────────────
# APP CONFIG  (optional -- sensible defaults)
# ────────────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8000
APP_LOG_LEVEL=INFO
APP_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
APP_WS_HEARTBEAT_SECONDS=30

# ────────────────────────────────────────────────────────────────
# AGENT CONFIG
# ────────────────────────────────────────────────────────────────
POLICY_CRAWLER_INTERVAL_SECONDS=3600        # hourly scan of regulatory sources
MONITORING_AGENT_INTERVAL_SECONDS=86400     # daily zero-LLM sweep across all 6 controls
EVENT_POLLER_INTERVAL_MS=500                # how often Impact Analysis polls schema_events + behavior_events
IMPACT_AGENT_TIMEOUT_SECONDS=30
AUDITOR_TIMEOUT_SECONDS=15
AUDITOR_REJECT_BLOCKS_PUBLISH=true          # if Auditor rejects, don't publish to cited.md or alert Datadog
AUDITOR_APPROVE_THRESHOLD=0.85              # >=this confidence = approved
AUDITOR_WARN_THRESHOLD=0.65                 # below this = rejected (between = approved_with_warnings)
