# ════════════════════════════════════════════════════════════════
# RegRadar -- Environment Configuration Template
#
# Copy this to .env and fill in values.
# .env is .gitignored -- never commit secrets.
#
# Architecture: free tier + BYOK. Every section is OPTIONAL except [A].
# Anyone can run the dashboard with just ClickHouse credentials; everything
# else lights up as you add keys.
#
# Sections:
#   [A] REQUIRED -- ClickHouse + at least one LLM key
#   [B] PUBLIC DEPLOY -- scheduler toggles, Turnstile, BYOK, SlowAPI
#   [C] OPTIONAL OBSERVABILITY -- Logfire (recommended) OR Datadog (sponsor-grade)
#   [D] OPTIONAL FEATURES -- Senso publishing, x402 monetization
#   [E] FRONTEND BUILD-TIME -- VITE_* vars set in Cloudflare Pages UI
#
# Save the populated .env to 1Password as "RegRadar -- .env (prod)".
# ════════════════════════════════════════════════════════════════


# ═══════════════════════════════════════════════════════════════════════════
# [A] REQUIRED
# ═══════════════════════════════════════════════════════════════════════════

# ────────────────────────────────────────────────────────────────
# CLICKHOUSE
# Free tier signup: clickhouse.cloud (no credit card, 30-day trial then
# free dev-tier). Daily auto-snapshots, 2 retained.
# ────────────────────────────────────────────────────────────────

# LOCAL (dev only)
# CLICKHOUSE_HOST=localhost
# CLICKHOUSE_PORT=8123
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=
# CLICKHOUSE_SECURE=false
# CLICKHOUSE_DATABASE=regradar

# CLOUD (production)
CLICKHOUSE_HOST=xxxxxxxxxx.us-east-1.aws.clickhouse.cloud
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_SECURE=true
CLICKHOUSE_DATABASE=regradar

# ────────────────────────────────────────────────────────────────
# LLM PROVIDER  (at least one of these three must resolve)
#
# Recommended for public release: OpenRouter.
#   - One key, 100+ models (Gemini / Claude / GPT / Llama / DeepSeek)
#   - Works for BYOK passthrough from arbitrary users
#   - Pay-as-you-go, no quota traps
#
# Resolution order in backend/integrations/vertex_ai.py:
#   1. OPENROUTER_API_KEY  (recommended)
#   2. GEMINI_API_KEY      (Google API-key path)
#   3. Vertex ADC          (GOOGLE_CLOUD_PROJECT + LOCATION + gcloud auth)
# ────────────────────────────────────────────────────────────────

# --- OpenRouter (recommended) ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Leave blank to auto-map gemini-3.5-flash -> google/gemini-2.5-flash.
# Override with any OpenRouter slug (e.g. anthropic/claude-3.5-sonnet).
OPENROUTER_MODEL=

# --- Direct Gemini API key (alternative to OpenRouter) ---
GEMINI_API_KEY=

# --- Vertex AI (alternative -- requires GCP project + ADC) ---
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=True

# Model names used internally (mapped to provider slugs by vertex_ai.py)
GEMINI_MODEL_DEFAULT=gemini-3.5-flash
GEMINI_MODEL_REASONING=gemini-3.1-pro
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# ────────────────────────────────────────────────────────────────
# SCRAPING  (at least one)
#
# Recommended for public release: Firecrawl.
#   - ~500 pages/mo free tier (renews monthly)
#   - Handles JS-rendered pages (eCFR works out of the box)
#
# Resolution order in backend/agents/policy_crawler.py:
#   1. Nimble (primary if NIMBLE_API_KEY set)
#   2. Firecrawl (fallback if Nimble returns <200 chars)
# ────────────────────────────────────────────────────────────────
NIMBLE_API_KEY=                              # optional -- 5k page one-time free trial
FIRECRAWL_API_KEY=                           # recommended -- monthly free tier

# ────────────────────────────────────────────────────────────────
# APP CONFIG
# ────────────────────────────────────────────────────────────────
APP_ENV=development                          # development | production
APP_PORT=8000                                # ignored on HF Spaces (Dockerfile hardcodes 7860)
APP_LOG_LEVEL=INFO

# CORS: comma-separated origins. Add your Cloudflare Pages URL in prod.
APP_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
# Prod example (uncomment + replace):
# APP_CORS_ORIGINS=https://regradar.pages.dev


# ═══════════════════════════════════════════════════════════════════════════
# [B] PUBLIC DEPLOY  (HF Spaces backend + Cloudflare Pages frontend)
# ═══════════════════════════════════════════════════════════════════════════

# ────────────────────────────────────────────────────────────────
# SCHEDULER TOGGLES
#
# For a public hosted demo: schedulers OFF by default (no 24/7 LLM burn).
# Demo trigger endpoint fires Impact Analysis on demand.
# Re-enable Policy Crawler once-daily if you want the dashboard to refresh
# overnight.
# ────────────────────────────────────────────────────────────────
ENABLE_SCHEDULERS=true                       # master switch -- false = pure on-demand
ENABLE_POLICY_CRAWLER=true                   # per-job toggle
ENABLE_IMPACT_ANALYSIS=true                  # per-job toggle

# Intervals (seconds). For public deploy, raise these to reduce LLM burn:
WATCHER_SCRAPE_INTERVAL_SECONDS=3600         # dev: 3600 (hourly). Prod: 86400 (daily).
IMPACT_AGENT_POLL_INTERVAL_SECONDS=60        # dev: 60. Prod: 300+ (5 min).
EVENT_POLLER_INTERVAL_MS=500                 # legacy -- Impact Analysis cursor poll cadence

# ────────────────────────────────────────────────────────────────
# CLOUDFLARE TURNSTILE  (bot protection on public LLM endpoints)
# Sign up: dash.cloudflare.com -> Turnstile -> Add Site
# Free, no rate limit on /siteverify
# ────────────────────────────────────────────────────────────────
TURNSTILE_ENABLED=false                      # true in prod
TURNSTILE_SITE_KEY=                          # public (also goes in Cloudflare Pages env as VITE_TURNSTILE_SITE_KEY)
TURNSTILE_SECRET_KEY=                        # server-only -- validates token via siteverify

# ────────────────────────────────────────────────────────────────
# BYOK (Bring Your Own Key) + SLOWAPI RATE LIMITING
#
# Three user tiers on a single endpoint:
#   1. Bot                 -> blocked by Turnstile, $0
#   2. Visitor, no key     -> demo pool (your server keys), SlowAPI-capped
#   3. Power user with key -> their key, no rate limit
#
# Header conventions (sent by frontend Settings modal):
#   X-User-LLM-Key + X-User-LLM-Provider          (provider: openrouter | gemini | anthropic | openai)
#   X-User-Scraper-Key + X-User-Scraper-Provider  (provider: firecrawl | nimble)
#
# Keys never logged. Stored client-side in localStorage. Server treats each
# request statelessly.
# ────────────────────────────────────────────────────────────────
BYOK_ENABLED=true                            # accept X-User-* headers
BYOK_BYPASS_RATE_LIMIT=true                  # users with their own key skip SlowAPI

# SlowAPI per-IP limits on demo-pool calls (when no BYOK header present)
DEMO_API_RATE_LIMIT=10/day                   # 10/day, 100/hour, 1/minute, etc.
DEMO_API_BURST_LIMIT=3/minute                # short-window throttle on top of daily cap

# Hard kill switch -- if today's total demo-pool LLM calls exceed this,
# /api/trigger returns 503 until UTC midnight.
DAILY_LLM_CALL_BUDGET=500


# ═══════════════════════════════════════════════════════════════════════════
# [C] OPTIONAL OBSERVABILITY  (pick zero, one, or both)
# ═══════════════════════════════════════════════════════════════════════════

# ────────────────────────────────────────────────────────────────
# LOGFIRE  (recommended)
# Pydantic AI's first-party trace UI. Built into pydantic-ai natively.
# Free tier: 10M spans/mo, 30-day retention.
# Sign up: logfire.pydantic.dev
# ────────────────────────────────────────────────────────────────
LOGFIRE_TOKEN=                               # leave blank to disable -- main.py guards on this var
LOGFIRE_SERVICE_NAME=regradar-backend

# ────────────────────────────────────────────────────────────────
# DATADOG  (alternative -- sponsor-grade LLM Obs cloud)
# Free trial: 14 days. Paid after.
# ────────────────────────────────────────────────────────────────
DD_API_KEY=
DD_SITE=datadoghq.com
DD_SERVICE=regradar-backend
DD_ENV=production
DD_LLMOBS_ENABLED=1
DD_LLMOBS_AGENTLESS_ENABLED=1
DD_LLMOBS_ML_APP=regradar


# ═══════════════════════════════════════════════════════════════════════════
# [D] OPTIONAL FEATURES  (skip unless you want these)
# ═══════════════════════════════════════════════════════════════════════════

# ────────────────────────────────────────────────────────────────
# SENSO  (publish Auditor-approved briefs to cited.md)
# Sign up: senso.ai
# Use case: turn each compliance finding into a public, citeable URL.
# ────────────────────────────────────────────────────────────────
SENSO_API_KEY=
SENSO_BASE_URL=https://apiv2.senso.ai
SENSO_PUBLISH_NAMESPACE=regradar             # cited.md/regradar/<slug>

# ────────────────────────────────────────────────────────────────
# x402 PAYMENT RAIL  (USDC micropayments for /api/compliance-brief)
# Use case: monetize compliance briefs for other agents to fetch.
# Most public-release users will skip this.
# ────────────────────────────────────────────────────────────────
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_NETWORK=base                            # base | base-sepolia | solana
X402_RECIPIENT_ADDRESS=
X402_PRICE_USDC_PER_BRIEF=0.001
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# ────────────────────────────────────────────────────────────────
# AUDITOR CONFIG  (when the Auditor agent ships)
# ────────────────────────────────────────────────────────────────
AUDITOR_TIMEOUT_SECONDS=15
AUDITOR_REJECT_BLOCKS_PUBLISH=true           # if rejected, do NOT publish to cited.md
AUDITOR_APPROVE_THRESHOLD=0.85
AUDITOR_WARN_THRESHOLD=0.65
IMPACT_AGENT_TIMEOUT_SECONDS=30
MONITORING_AGENT_INTERVAL_SECONDS=86400      # daily zero-LLM sweep


# ═══════════════════════════════════════════════════════════════════════════
# [E] FRONTEND BUILD-TIME VARS  (Vite)
#
# These do NOT belong in this .env. Set them in Cloudflare Pages ->
# Settings -> Environment variables (Build), so they're baked in at
# `npm run build` time.
#
# Save here for 1Password reference only.
# ═══════════════════════════════════════════════════════════════════════════

# VITE_API_URL=https://<your-hf-username>-regradar.hf.space
# VITE_TURNSTILE_SITE_KEY=<same as TURNSTILE_SITE_KEY above>
# VITE_ENABLE_BYOK=true
